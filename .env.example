# QuantStream Environment Configuration

# Redpanda
REDPANDA_BOOTSTRAP_SERVERS=localhost:9092
REDPANDA_SCHEMA_REGISTRY_URL=http://localhost:8081
REDPANDA_ADMIN_URL=http://localhost:9644

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=quantstream

# Spark
SPARK_MASTER=local[4]
SPARK_CHECKPOINT_DIR=s3a://quantstream/checkpoints/
SPARK_METRICS_ENABLED=true

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# DuckDB
DUCKDB_PATH=data/quantstream.duckdb

# Binance
BINANCE_SYMBOLS=btcusdt,ethusdt,bnbusdt
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Java (required for PySpark)
JAVA_HOME=/opt/homebrew/opt/openjdk@21
LOG_LEVEL=INFO
LOG_FORMAT=json
